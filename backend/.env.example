# Backend-only template (Render/Fly/Railway 등 API만 올릴 때 이 디렉터리 기준 env 설정).
# 루트 .env.example 에는 프론트(VITE_*)와 공통 설명이 함께 있습니다.

# LISTEN (기본 4720 — 이 레포 전용, 다른 앱 4000·5173과 섞이지 않음).
# PORT=4720

# CORS — 프론트 공개 출처를 쉼표로. 비우면 모든 출처 허용(로컬 편의).
# 분리 배포 시 프론트 도메인을 반드시 포함하세요.
# CORS_ORIGINS=https://your-app.example.com,http://localhost:5720

# JWT — 운영 필수, 최소 32자. 비우면 개발용 기본 시크릿(출시 금지).
# JWT_SECRET=your-long-random-secret-at-least-32-chars
# JWT_EXPIRES_SEC=86400

# NODE_ENV=production 이거나 STRICT_AUTH=true 이면 Bearer 없이 x-role 허용 안 함.
# STRICT_AUTH=true

# LOGIN_RATE_LIMIT_MAX=30
# API_RATE_LIMIT_MAX=600

# 리버스 프록시 뒤 배포 시 1
# TRUST_PROXY=1

# 시뮬레이션 매칭 엔진 틱(ms)
# MATCH_TICK_MS=8000

# 시드 데모 계정 공통 비밀번호(운영 전 교체)
# DEMO_SEED_PASSWORD=pass1234
