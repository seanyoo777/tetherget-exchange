# 프론트가 호출할 API 베이스 URL (끝 슬래시 없음).
# 비우면 브라우저와 같은 출처의 상대 경로 `/api` 사용 — 로컬에서는 Vite 프록시가 backend:4000으로 넘김.
# Vercel 등 프론트만 올리고 API가 다른 호스트면 여기에 백엔드 공개 URL을 넣고 재빌드.
# VITE_API_BASE=https://your-backend.example.com

# 헬스·레디 헤더 폴링 주기(ms). 생략 시 20000. 최소 5000 권장.
# VITE_API_PROBE_INTERVAL_MS=30000

# 백엔드(backend) 전용 — 프론트 도메인을 쉼표로 나열 (CORS). 비우면 모든 출처 허용(로컬 편의).
# CORS_ORIGINS=https://tgx-cex-2026.vercel.app,http://localhost:5173

# Bearer 없이 x-role 헤더 무시 (역할 위조 방지). NODE_ENV=production 이면 자동으로 켜짐.
# STRICT_AUTH=true

# JWT — 운영에서는 필수, 최소 32자. 비우면 개발 전용 기본 시크릿(출시 금지).
# JWT_SECRET=your-long-random-secret-at-least-32-chars
# JWT_EXPIRES_SEC=86400

# 로그인 시도 제한 (같은 IP, 15분 윈도우)
# LOGIN_RATE_LIMIT_MAX=30

# 분당 API 요청 상한 (같은 IP). GET /api/health, /api/ready, OPTIONS 는 제외.
# API_RATE_LIMIT_MAX=600

# 리버스 프록시 뒤에서 배포 시 1 — X-Forwarded-For·rate limit 정확도
# TRUST_PROXY=1

# 시드 유저 4명 공통 비밀번호 (개발·데모). 운영 전 교체·DB 이전 전제.
# DEMO_SEED_PASSWORD=pass1234
