{
  "name": "tetherget-exchange",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared/contracts",
    "backend"
  ],
  "scripts": {
    "prepare": "npm --prefix shared/contracts run build",
    "start": "npm run dev:full",
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm run dev --prefix backend",
    "dev:full": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm --prefix shared/contracts run build && tsc -b && vite build",
    "build:deploy": "npm --prefix shared/contracts run build && npm --prefix backend run build",
    "start:api": "npm --prefix backend run start",
    "preview": "vite preview --open --host",
    "preview:full": "npm run build && concurrently -n web,api -c cyan,magenta \"vite preview --host --port 4173\" \"npm run dev --prefix backend\"",
    "tunnel": "npx --yes localtunnel --port 5173",
    "tunnel:preview": "npx --yes localtunnel --port 4173",
    "test": "vitest run",
    "report:completion": "node scripts/completion-report.mjs"
  },
  "dependencies": {
    "@tetherget/contracts": "file:./shared/contracts",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  }
}
